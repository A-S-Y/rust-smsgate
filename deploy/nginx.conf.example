server {
    listen 80;
    server_name alsiyniisms.ddns.net;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name alsiyniisms.ddns.net;

    ssl_certificate /etc/letsencrypt/live/alsiyniisms.ddns.net/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/alsiyniisms.ddns.net/privkey.pem;

    location /api/ws {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location / {
        root /opt/rust-smsgate/frontend/dist;
        try_files $uri $uri/ /index.html;
    }
}
